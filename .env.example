# LaunchPard — environment template
# Copy to `.env.local` (dev) or set in Vercel project settings (prod).
# Schema and validation: src/lib/env.ts — boot fails if any required var is missing or malformed.
#
# Rotation cadence column legend:
#   30d = every 30 days · 90d = every 90 days · ON-LEAK = only when suspected/known leaked
#
# If you add a var here, add it to src/lib/env.ts too.

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development                          # production | development | test
LOG_LEVEL=info                                # debug | info | warn | error

# ─── Supabase ────────────────────────────────────────────────────────────────
# April 22 2026 migration: moving from legacy JWT-based `anon` / `service_role`
# keys to the new publishable + secret API key model. The legacy JWT secret
# cannot be rotated on demand without standby+revoke flow; the new keys can.
#
# Resolution rule (see src/lib/env.ts — `supabaseKeys`):
#   - Prefer new keys (SUPABASE_SECRET_KEY, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY).
#   - Fall back to legacy (SUPABASE_SERVICE_ROLE_KEY, NEXT_PUBLIC_SUPABASE_ANON_KEY).
#   - A one-time warning logs when a fallback is used, so we can watch the migration drain.
#   - In prod, at least one of each pair must be set or boot fails.
#
# Rotation (new keys):
#   SUPABASE_SECRET_KEY         → 90d cadence, IMMEDIATELY ON-LEAK. Server-only.
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY → URL/key are stable by design (RLS enforces access).
#
# Rotation (legacy, while still used):
#   SUPABASE_SERVICE_ROLE_KEY   → standby-then-revoke only. Migrate off instead.
#   NEXT_PUBLIC_SUPABASE_ANON_KEY → JWT, public by design.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# NEW (preferred) — set these in Vercel alongside the legacy keys, then flip.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # safe in the browser under RLS
SUPABASE_SECRET_KEY=sb_secret_...                         # SERVER ONLY — bypasses RLS. 90d/ON-LEAK

# LEGACY — keep set during migration. Delete once new keys are green for 24h.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # legacy JWT, public by design
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...       # legacy JWT, SERVER ONLY
# SUPABASE_SERVICE_KEY=                       # LEGACY alias — still read by 2 cron routes. Delete after migration.
# SUPABASE_URL=                               # LEGACY alias — falls back to NEXT_PUBLIC_SUPABASE_URL.

# ─── AI providers ────────────────────────────────────────────────────────────
# Rotation: 90d, or ON-LEAK.
OPENROUTER_API_KEY=sk-or-v1-...               # Tara tutor/feedback via OpenRouter
OPENAI_API_KEY=sk-...                         # Optional — secondary provider

# ─── Email (transactional) ───────────────────────────────────────────────────
# Rotation: 90d, or ON-LEAK. Both providers used — Brevo for campaigns, Resend for txn.
BREVO_API_KEY=xkeysib-...
BREVO_BETA_LIST_ID=3                          # numeric list id for beta signups
RESEND_API_KEY=re_...

# ─── Cron + admin ────────────────────────────────────────────────────────────
# Rotation: CRON_SECRET 90d or ON-LEAK. ADMIN_EMAILS updated when team changes.
CRON_SECRET=                                   # 32+ random chars — protects /api/cron/*
ADMIN_EMAILS=rotimi@launchpard.com             # comma-separated allow-list

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Rotation: 180d. If missing in prod, rate limiter falls open (logs warning).
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Payments — Paystack (Nigeria) ───────────────────────────────────────────
# Rotation: 90d. Rotate webhook secret whenever checkout URL changes.
PAYSTACK_SECRET_KEY=sk_live_...                # awaiting account activation
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=

# ─── Payments — Stripe (UK, awaiting entity) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── URLs ────────────────────────────────────────────────────────────────────
APP_URL=https://launchpard.com                 # server-side absolute URLs
NEXT_PUBLIC_APP_URL=https://launchpard.com     # client-side absolute URLs (must match APP_URL in prod)

# ─── Observability ───────────────────────────────────────────────────────────
# Sentry DSNs are not secrets per Sentry docs, but log them anyway.
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── CSP (Phase 5) ───────────────────────────────────────────────────────────
CSP_ENFORCE=0                                  # "1" to enforce (after 48h of Report-Only is clean)
CSP_REPORT_URI=                                # optional report endpoint

# ─── Client-only extras ──────────────────────────────────────────────────────
NEXT_PUBLIC_TTS_API_URL=                       # optional external TTS endpoint
NEXT_PUBLIC_VAPID_PUBLIC_KEY=                  # web-push public key
